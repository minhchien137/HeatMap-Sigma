                                                    color: #ef4444;
                                                    font-size: 1rem;
                                                    cursor: pointer;
                                                    display: flex;
                                                    align-items: center;
                                                    justify-content: center;
                                                    transition: all 0.15s;
                                                    flex-shrink: 0;
                                                }

                                                .bulk-delete-btn:hover {
                                                    background: #fef2f2;
                                                    border-color: #ef4444;
                                                }

                                                .bulk-add-btn {
                                                    width: 100%;
                                                    padding: 9px 14px;
                                                    background: #f9fafb;
                                                    border: none;
                                                    border-top: 1px dashed #e5e7eb;
                                                    color: #dc2626;
                                                    font-size: 0.85rem;
                                                    font-weight: 700;
                                                    cursor: pointer;
                                                    text-align: left;
                                                    transition: background 0.15s;
                                                }

                                                .bulk-add-btn:hover {
                                                    background: #fef2f2;
                                                }

                                                /* Employee tab switcher */
                                                .bulk-emp-tab {
                                                    padding: 7px 16px;
                                                    border-radius: 999px;
                                                    border: 2px solid #e5e7eb;
                                                    font-size: 0.85rem;
                                                    font-weight: 700;
                                                    color: #6b7280;
                                                    background: white;
                                                    cursor: pointer;
                                                    transition: all 0.15s;
                                                    white-space: nowrap;
                                                }

                                                .bulk-emp-tab:hover {
                                                    border-color: #dc2626;
                                                    color: #dc2626;
                                                }

                                                .bulk-emp-tab.active {
                                                    background: #dc2626;
                                                    border-color: #dc2626;
                                                    color: white;
                                                    box-shadow: 0 4px 12px rgba(220,38,38,0.25);
                                                }

                                                /* ===== GLOBAL MOBILE RESPONSIVE ===== */
                                                @@media (max-width: 640px) {
                                                    /* Card padding nhỏ hơn */
                                                    .bg-white.rounded-\[3rem\] {
                                                        padding: 1.5rem !important;
                                                        border-radius: 1.5rem !important;
                                                    }

                                                    /* Title nhỏ hơn */
                                                    .text-5xl { font-size: 2.25rem !important; }
                                                    .text-6xl { font-size: 2.5rem  !important; }

                                                    /* Submit btn full width */
                                                    .submit-btn {
                                                        width: 100%;
                                                        padding: 0.9rem 1.5rem;
                                                        letter-spacing: 0.1em;
