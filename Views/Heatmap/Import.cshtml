                                                        grid-template-columns: 1fr 1fr;
                                                        grid-template-rows: auto auto auto;
                                                        gap: 8px;
                                                        padding: 12px 14px;
                                                        position: relative;
                                                    }

                                                    /* Customer chiếm full width */
                                                    .bulk-project-row .bulk-customer {
                                                        grid-column: 1 / -1;
                                                    }

                                                    /* Project chiếm full width */
                                                    .bulk-project-row .bulk-project {
                                                        grid-column: 1 / -1;
                                                    }

                                                    /* ProjectPhase + Phase nằm cạnh nhau */
                                                    .bulk-project-row .bulk-pp,
                                                    .bulk-project-row .bulk-phase {
                                                        grid-column: span 1;
                                                    }

