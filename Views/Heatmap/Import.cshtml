@{
    Layout = "_Layout";
    ViewData["Title"] = "Nhập dữ liệu";
    ViewData["PageName"] = "Import";
}

<div class="w-full max-w-6xl mx-auto">
    <div
        class="bg-white rounded-[3rem] shadow-[0_35px_80px_rgba(0,0,0,0.08)] overflow-hidden p-12 md:p-16 animate-fade-in border border-gray-50 min-h-[700px]">

        <!-- Header -->
        <div class="text-center mb-8">
            <h2 class="text-gray-400 font-black uppercase tracking-[0.3em] mb-3 text-xs">Nhập dữ liệu</h2>
            <h1 class="text-5xl md:text-6xl font-black leading-[1.1] text-red-600">
                Heatmap
            </h1>
        </div>

        <!-- Mode Selector (3 Tabs) -->
        <div class="mb-10">
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <button id="modeBtn1" onclick="switchMode(1)"
                        class="mode-btn active px-5 py-3 rounded-2xl font-bold text-sm transition-all border-2 w-full sm:w-auto">
                    Nhập đơn (1 người - 1 ngày)
                </button>
                <button id="modeBtn2" onclick="switchMode(2)"
                        class="mode-btn px-5 py-3 rounded-2xl font-bold text-sm transition-all border-2 w-full sm:w-auto">
                    Một người - Nhiều ngày
                </button>
                <button id="modeBtn3" onclick="switchMode(3)"
                        class="mode-btn px-5 py-3 rounded-2xl font-bold text-sm transition-all border-2 w-full sm:w-auto">
                    Nhiều người - Nhiều ngày
                </button>
            </div>
        </div>

        <!-- MODE 1: Nhập đơn -->
        <div id="mode1" class="mode-content">
            <div class="flex flex-col lg:flex-row gap-10">
                <!-- Left Column -->
                <div class="flex-[2] space-y-6">
                    <!-- Bộ phận -->
                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Bộ
                            phận</label>
                            <select id="department1" class="input-field">
                                <option value="">-- Chọn bộ phận --</option>
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.id">@dept.dept_name</option>
                                }
                            </select>
                        </div>

                        <!-- Tên -->
                        <div class="group">
                            <label
                            class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Tên</label>
                            <!-- Hidden select - giữ nguyên để submit code không đổi -->
                            <select id="employee1" class="hidden" aria-hidden="true">
                                <option value="">-- Chọn bộ phận trước --</option>
                            </select>
                            <!-- Custom searchable dropdown -->
                            <div class="searchable-select" id="employee1-sd" data-target="employee1">
                                <div class="searchable-select-trigger input-field" onclick="toggleSearchableSelect('employee1-sd')">
                                    <span class="searchable-select-display">-- Chọn bộ phận trước --</span>
                                    <svg class="searchable-select-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                                </div>
                                <div class="searchable-select-dropdown">
                                    <div class="searchable-select-search-wrap">
                                        <input class="searchable-select-search" placeholder="Tìm nhân viên..." oninput="filterSearchableSelect('employee1-sd', this.value)" />
                                    </div>
                                    <div class="searchable-select-options">
                                        <div class="searchable-select-placeholder">-- Chọn bộ phận trước --</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Dự án (multi) -->
                        <div class="group">
                            <div class="flex items-center justify-between mb-2 ml-2">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-400">Dự án & Giờ làm</label>
                            </div>
                            <!-- Column labels -->
                            <div class="bulk-row-label" style="border-radius:0.75rem 0.75rem 0 0; border:2px solid #e5e7eb; border-bottom:1px solid #f3f4f6;">
                                <span>Customer</span><span>Project</span><span>Proj.Phase</span><span>Phase</span><span>Số giờ</span><span></span>
                            </div>
                            <!-- Rows container -->
                            <div id="projectRows1" style="border:2px solid #e5e7eb; border-top:none; border-bottom:none;"></div>
                            <!-- Add button -->
                            <button type="button" class="bulk-add-btn" style="border-radius:0 0 0.75rem 0.75rem; border:2px solid #e5e7eb; border-top:1px dashed #e5e7eb;"
                                    onclick="addMode1ProjectRow()">+ Thêm dự án</button>
                        </div>

                        <!-- Tuần -->
                        <div class="group">
                            <label
                            class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Tuần</label>
                            <select id="week1" class="input-field">
                                <option value="">-- Chọn tuần --</option>
                            </select>
                        </div>

                        <!-- Ngày -->
                        <div class="group">
                            <label
                            class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Ngày</label>
                            <input type="date" id="day1" class="input-field" />
                        </div>
                    </div>

                    <!-- Right Column - Image -->
                    <div class="flex-1 hidden lg:flex flex-col items-center justify-start">
                        <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-3">Image
                            User</label>
                            <div class="upload-box">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     class="h-12 w-12 mx-auto mb-3 text-gray-300 group-hover:text-red-400 transition-colors"
                                     fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <p class="font-bold text-xs">Comming soon</p>
                                <p class="text-[10px] mt-1 opacity-60">Coming soon</p>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="mt-12 text-center">
                        <button onclick="handleSubmitMode1()" class="submit-btn w-full sm:w-auto">
                            Lưu dữ liệu
                        </button>
                    </div>
                </div>

                <!-- MODE 2: Nhiều ngày - 1 người -->
                <div id="mode2" class="mode-content hidden">
                    <div class="space-y-6 max-w-3xl mx-auto">
                        <!-- Bộ phận -->
                        <div class="group">
                            <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Bộ
                                phận</label>
                                <select id="department2" class="input-field">
                                    <option value="">-- Chọn bộ phận --</option>
                                    @foreach (var dept in ViewBag.Departments)
                                    {
                                        <option value="@dept.id">@dept.dept_name</option>
                                    }
                                </select>
                            </div>

                            <!-- Tên -->
                            <div class="group">
                                <label
                                class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Tên</label>
                                <!-- Hidden select - giữ nguyên để submit code không đổi -->
                                <select id="employee2" class="hidden" aria-hidden="true">
                                    <option value="">-- Chọn bộ phận trước --</option>
                                </select>
                                <!-- Custom searchable dropdown -->
                                <div class="searchable-select" id="employee2-sd" data-target="employee2">
                                    <div class="searchable-select-trigger input-field" onclick="toggleSearchableSelect('employee2-sd')">
                                        <span class="searchable-select-display">-- Chọn bộ phận trước --</span>
                                        <svg class="searchable-select-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                                    </div>
                                    <div class="searchable-select-dropdown">
                                        <div class="searchable-select-search-wrap">
                                            <input class="searchable-select-search" placeholder="Tìm nhân viên..." oninput="filterSearchableSelect('employee2-sd', this.value)" />
                                        </div>
                                        <div class="searchable-select-options">
                                            <div class="searchable-select-placeholder">-- Chọn bộ phận trước --</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tuần -->
                            <div class="group">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Tuần</label>
                                <select id="week2" class="input-field">
                                    <option value="">-- Chọn tuần --</option>
                                </select>
                            </div>

                            <!-- Chọn các ngày trong tuần -->
                            <div class="group">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-3 ml-2">Chọn ngày</label>
                                <div id="dayCheckboxes2" class="grid grid-cols-1 gap-3">
                                    <p class="text-gray-400 text-center py-4">Vui lòng chọn tuần</p>
                                </div>
                            </div>

                            <!-- List nhập dự án & giờ cho từng ngày -->
                            <div class="group" id="dayHoursSection2" style="display: none;">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-400 ml-2">Nhập dự án & giờ làm việc</label>
                                    <button type="button" onclick="copyFirstDayDataToAll()" id="copyFirstDayBtn"
                                            class="copy-btn text-xs px-4 py-2 rounded-lg transition-all font-semibold self-start sm:self-auto">
                                        📋 Copy ngày đầu cho tất cả
                                    </button>
                                </div>
                                <div id="dayHoursList2" class="space-y-3">
                                    <p class="text-gray-400 text-center py-4">Chưa chọn ngày nào</p>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="text-center mt-10">
                                <button onclick="handleSubmitMode2()" class="submit-btn w-full sm:w-auto">
                                    Lưu dữ liệu
                                </button>
                            </div>
                        </div>
                    </div>

                <!-- MODE 3: Nhiều người - Nhiều ngày -->
                <div id="mode3" class="mode-content hidden">
                    <div class="space-y-6 max-w-3xl mx-auto">
                        <!-- Bộ phận -->
                        <div class="group">
                            <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Bộ phận</label>
                            <select id="department3" class="input-field">
                                <option value="">-- Chọn bộ phận --</option>
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.id">@dept.dept_name</option>
                                }
                            </select>
                        </div>

                        <!-- Chọn nhân viên (checkboxes) -->
                        <div class="group">
                            <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-3 ml-2">Chọn nhân viên</label>
                            <div id="employeeCheckboxes3" class="grid grid-cols-1 md:grid-cols-2 gap-3 max-h-60 overflow-y-auto">
                                <p class="text-gray-400 text-center py-4">Vui lòng chọn bộ phận</p>
                            </div>
                        </div>

                        <!-- Tuần -->
                        <div class="group">
                            <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-2">Tuần</label>
                            <select id="week3" class="input-field">
                                <option value="">-- Chọn tuần --</option>
                            </select>
                        </div>

                        <!-- Chọn các ngày trong tuần -->
                        <div class="group">
                            <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-3 ml-2">Chọn ngày</label>
                            <div id="dayCheckboxes3" class="grid grid-cols-1 gap-3">
                                <p class="text-gray-400 text-center py-4">Vui lòng chọn tuần</p>
                            </div>
                        </div>

                        <!-- Button nhập dữ liệu hàng loạt -->
                        <div class="text-center mt-10">
                            <button onclick="showBulkInputPopup()" class="submit-btn w-full sm:w-auto">
                                Nhập dữ liệu hàng loạt
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Back to Home Button -->
                <div class="text-center mt-10">
                    <a href="/Heatmap/Home"
                           class="inline-flex items-center gap-3 px-8 py-4 bg-gray-900 text-white rounded-2xl font-bold hover:bg-gray-800 transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                        Về trang chủ
                    </a>
                </div>
                                            </div>

                                            <!-- Bulk Input Popup (Mode 3) -->
                                            <div id="bulkInputPopup"
                                                 class="fixed inset-0 z-[100] hidden items-center justify-center px-2 sm:px-4 bg-black/70 backdrop-blur-md">
                                                <div class="bg-white rounded-none sm:rounded-[2.5rem] shadow-2xl w-full sm:max-w-3xl h-full sm:h-auto sm:max-h-[90vh] overflow-hidden border border-gray-100 flex flex-col">
                                                    <!-- Header -->
                                                    <div class="px-4 sm:px-8 py-4 sm:py-6 border-b border-gray-100 flex-shrink-0">
                                                        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-4">
                                                            <div>
                                                                <h3 class="text-xl sm:text-2xl font-black text-gray-900">Nhập dữ liệu hàng loạt</h3>
                                                                <p class="text-sm text-gray-400 mt-1">Mỗi nhân viên có thể làm nhiều dự án trong một ngày</p>
                                                            </div>
                                                            <div class="flex items-center gap-3 flex-shrink-0">
                                                                <button type="button" onclick="copyFirstDayToAllMode3()"
                                                                        class="copy-btn text-xs px-3 py-2 rounded-lg transition-all font-semibold whitespace-nowrap">
                                                                    📋 Copy ngày đầu
                                                                </button>
                                                                <div id="bulkSummary" class="text-xs text-gray-400 font-semibold text-right"></div>
                                                            </div>
                                                        </div>
                                                        <!-- Employee switcher -->
                                                        <div class="flex gap-2 flex-wrap overflow-x-auto pb-1" id="bulkEmpTabs">
                                                            <!-- Tab buttons generated by JS -->
                                                        </div>
                                                    </div>
                                                    <!-- Blocks container -->
                                                    <div class="overflow-y-auto flex-1 p-3 sm:p-6">
                                                        <div id="bulkInputBlocks" class="space-y-4">
                                                        </div>
                                                    </div>
                                                    <!-- Footer -->
                                                    <div class="px-4 sm:px-8 py-4 sm:py-5 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
                                                        <button onclick="closeBulkInputPopup()"
                                                                class="flex-1 sm:flex-none px-5 py-3 border-2 border-gray-100 rounded-2xl font-bold text-gray-400 hover:bg-gray-50 transition-all">
                                                            Hủy
                                                        </button>
                                                        <button onclick="handleSubmitMode3()"
                                                                class="flex-1 sm:flex-none px-5 py-3 bg-red-600 text-white rounded-2xl font-bold shadow-xl shadow-red-100 hover:bg-red-700 transition-all">
                                                            Xác nhận lưu
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Confirm Modal -->
                                            <div id="confirmModal"
                                                 class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-black/70 backdrop-blur-md">
                                                <div class="bg-white p-8 sm:p-12 rounded-[2.5rem] shadow-2xl max-w-md w-full text-center border border-gray-100">
                                                    <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mb-8 mx-auto">
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-red-600" fill="none" viewBox="0 0 24 24"
                                                             stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                  d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                        </svg>
                                                    </div>
                                                    <h3 class="text-3xl font-black mb-4 tracking-tight">Xác nhận?</h3>
                                                    <p class="text-gray-500 text-lg mb-10 leading-relaxed" id="confirmMessage"></p>
                                                    <div class="flex space-x-5">
                                                        <button onclick="closeConfirmModal()"
                                                                class="flex-1 py-4 border-2 border-gray-100 rounded-2xl font-bold text-gray-400 hover:bg-gray-50 transition-all">
                                                            Không
                                                        </button>
                                                        <button onclick="confirmSubmit()"
                                                                class="flex-1 py-4 bg-red-600 text-white rounded-2xl font-bold shadow-xl shadow-red-100 hover:bg-red-700 transition-all">
                                                            Có, xác nhận
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Error Modal -->
                                            <div id="errorModal" class="fixed inset-0 z-[110] hidden items-center justify-center px-4 bg-black/70 backdrop-blur-md">
                                                <div class="bg-white p-8 sm:p-12 rounded-[2.5rem] shadow-2xl max-w-md w-full text-center border border-gray-100">
                                                    <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mb-8 mx-auto">
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-red-600" fill="none" viewBox="0 0 24 24"
                                                             stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                                        </svg>
                                                    </div>
                                                    <h3 class="text-3xl font-black mb-4 tracking-tight">Thông báo</h3>
                                                    <p id="errorModalMessage" class="text-gray-500 text-lg mb-10 leading-relaxed"></p>
                                                    <button onclick="closeErrorModal()"
                                                            class="w-full py-4 bg-black text-white rounded-2xl font-bold shadow-xl transition-all hover:bg-zinc-800">
                                                        Đã hiểu
                                                    </button>
                                                </div>
                                            </div>

                                            <style>
                                                /* ===== SEARCHABLE SELECT ===== */
                                                .searchable-select {
                                                    position: relative;
                                                    width: 100%;
                                                }

                                                .searchable-select-trigger {
                                                    display: flex;
                                                    align-items: center;
                                                    justify-content: space-between;
                                                    cursor: pointer;
                                                    user-select: none;
                                                }

                                                .searchable-select-trigger:hover {
                                                    border-color: #dc2626;
                                                }

                                                .searchable-select-trigger.open {
                                                    border-color: #dc2626;
                                                    border-bottom-left-radius: 0;
                                                    border-bottom-right-radius: 0;
                                                }

                                                .searchable-select-arrow {
                                                    color: #9ca3af;
                                                    flex-shrink: 0;
                                                    transition: transform 0.2s ease;
                                                }

                                                .searchable-select-trigger.open .searchable-select-arrow {
                                                    transform: rotate(180deg);
                                                    color: #dc2626;
                                                }

                                                .searchable-select-display {
                                                    color: #6b7280;
                                                    overflow: hidden;
                                                    text-overflow: ellipsis;
                                                    white-space: nowrap;
                                                    flex: 1;
                                                }

                                                .searchable-select-display.selected {
                                                    color: #1f2937;
                                                }

                                                .searchable-select-dropdown {
                                                    display: none;
                                                    position: absolute;
                                                    top: 100%;
                                                    left: 0;
                                                    right: 0;
                                                    background: white;
                                                    border: 2px solid #dc2626;
                                                    border-top: none;
                                                    border-bottom-left-radius: 1rem;
                                                    border-bottom-right-radius: 1rem;
                                                    box-shadow: 0 10px 40px rgba(0,0,0,0.12);
                                                    z-index: 999;
                                                    overflow: hidden;
                                                }

                                                .searchable-select-dropdown.open {
                                                    display: block;
                                                }

                                                .searchable-select-search-wrap {
                                                    padding: 10px 12px;
                                                    border-bottom: 1px solid #f3f4f6;
                                                    background: #fafafa;
                                                }

                                                .searchable-select-search {
                                                    width: 100%;
                                                    padding: 8px 12px;
                                                    border: 1.5px solid #e5e7eb;
                                                    border-radius: 0.5rem;
                                                    font-size: 0.9rem;
                                                    outline: none;
                                                    background: white;
                                                    transition: border-color 0.2s;
                                                }

                                                .searchable-select-search:focus {
                                                    border-color: #dc2626;
                                                }

                                                .searchable-select-options {
                                                    max-height: 220px;
                                                    overflow-y: auto;
                                                    padding: 6px 0;
                                                }

                                                .searchable-select-item {
                                                    padding: 10px 16px;
                                                    cursor: pointer;
                                                    font-size: 0.95rem;
                                                    color: #374151;
                                                    transition: background 0.15s;
                                                }

                                                .searchable-select-item:hover {
                                                    background: #fef2f2;
                                                    color: #dc2626;
                                                }

                                                .searchable-select-item.active {
                                                    background: #fef2f2;
                                                    color: #dc2626;
                                                    font-weight: 700;
                                                }

                                                .searchable-select-item.hidden-item {
                                                    display: none;
                                                }

                                                .searchable-select-placeholder {
                                                    padding: 12px 16px;
                                                    color: #9ca3af;
                                                    font-size: 0.9rem;
                                                    text-align: center;
                                                }

                                                .searchable-select-empty {
                                                    padding: 12px 16px;
                                                    color: #9ca3af;
                                                    font-size: 0.9rem;
                                                    text-align: center;
                                                }
                                            </style>
                                            <style>
                                                .input-field {
                                                    width: 100%;
                                                    padding: 1rem 1.5rem;
                                                    background-color: white;
                                                    border: 2px solid #e5e7eb;
                                                    border-radius: 1rem;
                                                    outline: none;
                                                    transition: all 0.3s;
                                                    font-size: 1rem;
                                                    color: #1f2937;
                                                }

                                                .input-field:focus {
                                                    background-color: white;
                                                    border-color: #dc2626;
                                                    ring: 0;
                                                }

                                                /* Specific styles for day hours list inputs */
                                                #dayHoursList2 .input-field {
                                                    background-color: white;
                                                    border-color: #d1d5db;
