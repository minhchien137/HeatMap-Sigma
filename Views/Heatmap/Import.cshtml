                                                    gap: 10px;
                                                    padding: 6px 14px;
                                                    background: #fafafa;
                                                    border-bottom: 1px solid #f3f4f6;
                                                }

                                                /* Mobile: stack project rows vertically */
                                                @@media (max-width: 640px) {
                                                    .bulk-row-label {
                                                        display: none;
