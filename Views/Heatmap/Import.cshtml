                                                    background-color: white;
                                                    border: 2px solid #e5e7eb;
                                                    border-radius: 1rem;
                                                    cursor: pointer;
                                                    transition: all 0.3s;
                                                }

                                                .day-checkbox:hover,
                                                .employee-checkbox:hover {
                                                    border-color: #dc2626;
                                                    background-color: #fef2f2;
                                                }

                                                .day-checkbox.selected,
                                                .employee-checkbox.selected {
                                                    border-color: #dc2626;
                                                    background-color: #fef2f2;
                                                    font-weight: bold;
