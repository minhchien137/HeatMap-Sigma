                                                    .bulk-project-row .bulk-hours-input {
                                                        grid-column: span 1;
                                                    }

                                                    .bulk-project-row .bulk-delete-btn {
                                                        grid-column: span 1;
                                                        justify-self: end;
                                                        align-self: center;
                                                    }
                                                }

                                                .bulk-row-label span {
                                                    font-size: 0.7rem;
